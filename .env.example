# 亚马逊选品系统环境变量配置
# 复制此文件为 .env 并填入实际值

# =====================
# 数据库配置
# =====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amazon_selector
DB_USER=postgres
DB_PASSWORD=your_password_here

# =====================
# 亚马逊 API 配置
# =====================
# 方案 A: Rainforest API (推荐，即时可用)
RAINFOREST_API_KEY=your_rainforest_api_key

# 方案 B: SP-API (官方，需申请)
AMAZON_SP_API_ID=your_sp_api_id
AMAZON_SP_API_SECRET=your_sp_api_secret
AMAZON_SP_API_REGION=us-east-1

# 采集频率控制 (秒)
AMAZON_REQUEST_DELAY=1.0
AMAZON_MAX_RETRIES=3

# 代理池 (逗号分隔)
AMAZON_PROXY_POOL=proxy1.example.com:8080,proxy2.example.com:8080

# =====================
# 1688 配置
# =====================
ALIBABA_REQUEST_DELAY=1.0
ALIBABA_MAX_RETRIES=3
ALIBABA_PROXY_POOL=proxy1.example.com:8080,proxy2.example.com:8080

# =====================
# 分析配置
# =====================
TOP_N_PRODUCTS=20
TOP_N_SUPPLIERS=10

# =====================
# 日志配置
# =====================
LOG_LEVEL=INFO
